# =========================================
# PSHAD Sentinel iHub - Environment Config
# =========================================
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- OpenWeatherMap (FREE tier - 1000 calls/day) ---
# Get yours at: https://openweathermap.org/api
EXPO_PUBLIC_OPENWEATHERMAP_API_KEY=

# --- EskomSePush (Optional - 40 calls/day) ---
# Get yours at: https://eskomsepush.gumroad.com/l/api
EXPO_PUBLIC_ESKOMSEPUSH_API_KEY=

# --- Firebase (Optional - for push notifications) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- App ---
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.267.0
