# =========================================
# PSHAD Sentinel iHub — Environment Config
# =========================================
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# Get values from team lead or Firebase console

# --- Firebase ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- News API ---
EXPO_PUBLIC_NEWS_API_KEY=
EXPO_PUBLIC_NEWS_API_BASE_URL=

# --- Map ---
EXPO_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# --- App ---
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.263.1